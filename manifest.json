{
  "manifest_version": 3,
  "name": "Rename Tab",
  "version": "1.0",
  "description": "Rename any tab with a keyboard shortcut",
  "permissions": ["activeTab", "scripting"],
  "commands": {
    "rename-tab": {
      "suggested_key": {
        "default": "Alt+R",
        "mac": "MacCtrl+Shift+R"
      },
      "description": "Rename the current tab"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
